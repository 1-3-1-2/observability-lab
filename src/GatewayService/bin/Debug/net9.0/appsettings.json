{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "providers-route": {
        "ClusterId": "providers-cluster",
        "Match": {
          "Path": "/providers/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/providers" }
        ]
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api-service": {
            "Address": "http://apiservice:8080"
          }
        }
      },
      "providers-cluster": {
        "Destinations": {
          "provider-service": {
            "Address": "http://providerservice:8080"
          }
        }
      }
    }
  }
}
